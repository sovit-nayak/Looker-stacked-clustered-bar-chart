      "label": "Chart Style",
      "elements": [
        {
          "id": "barColors",
          "label": "Color Palette",
          "type": "SELECT_SINGLE",
          "defaultValue": "vibrant",
          "options": [
            { "label": "Vibrant", "value": "vibrant" },
            { "label": "Pastel", "value": "pastel" },
            { "label": "Corporate", "value": "corporate" }
          ]
        },
        {
          "id": "showLegend",
          "label": "Show Legend",
          "type": "CHECKBOX",
          "defaultValue": true
        },
        {
          "id": "showValues",
          "label": "Show Data Labels",
          "type": "CHECKBOX",
          "defaultValue": false
        },
        {
          "id": "borderRadius",
          "label": "Bar Corner Radius",
          "type": "SELECT_SINGLE",
          "defaultValue": "2",
          "options": [
            { "label": "None", "value": "0" },
            { "label": "Small", "value": "2" },
            { "label": "Medium", "value": "6" }
          ]
        },
        {
          "id": "chartTitle",
          "label": "Chart Title",
          "type": "TEXTINPUT",
          "defaultValue": ""
