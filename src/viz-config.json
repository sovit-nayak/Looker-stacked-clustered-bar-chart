{
  "data": [
    {
      "id": "concepts",
      "label": "Data",
      "elements": [
        {
          "id": "timeDimension",
          "label": "Time Period (X-Axis)",
          "type": "DIMENSION",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "comparisonDimension",
          "label": "Comparison Group (e.g. LY vs TY)",
          "type": "DIMENSION",
          "options": { "min": 1, "max": 1 }
        },
        {
          "id": "metric",
          "label": "Stacked Metrics",
          "type": "METRIC",
          "options": { "min": 1, "max": 10 }
        }
      ]
    }
  ],
  "style": [
    {
      "id": "titleSection",
      "label": "Chart Title",
      "elements": [
        {
          "id": "showTitle",
          "label": "Show Title",
          "type": "CHECKBOX",
          "defaultValue": true
        },
        {
          "id": "chartTitle",
          "label": "Title",
          "type": "TEXTINPUT",
          "defaultValue": "Y/Y Revenue"
        },
        {
          "id": "titleFontFamily",
          "label": "Font Family",
          "type": "SELECT_SINGLE",
          "defaultValue": "Arial",
          "options": [
            { "label": "Arial", "value": "Arial" },
            { "label": "Roboto", "value": "Roboto" },
            { "label": "Open Sans", "value": "Open Sans" },
            { "label": "Lato", "value": "Lato" },
            { "label": "Google Sans", "value": "Google Sans" },
            { "label": "Montserrat", "value": "Montserrat" }
          ]
        },
        {
          "id": "titleFontSize",
          "label": "Font Size",
          "type": "SELECT_SINGLE",
          "defaultValue": "20",
          "options": [
            { "label": "14px", "value": "14" },
            { "label": "16px", "value": "16" },
            { "label": "18px", "value": "18" },
            { "label": "20px", "value": "20" },
            { "label": "24px", "value": "24" }
          ]
        },
        {
          "id": "titleFontColor",
          "label": "Font Color",
          "type": "FONT_COLOR",
          "defaultValue": {
            "color": "#000000"
